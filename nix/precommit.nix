# Pre-commit / git-hooks integration for the dev shell.
#
# git-hooks.nix installs the git hooks from its own shellHook, but in this repo
# two things break `git commit` / `git push` that it does not handle, so we
# layer a self-heal on top of it. Importing this file keeps that machinery out
# of flake.nix.
#
# Usage from flake.nix:
#
#   precommit = import ./nix/precommit.nix {
#     inherit pkgs;
#     patchedPreCommit = git-hooks.packages.${system}.pre-commit;
#     preCommitCheck = self.checks.${system}.pre-commit-check;
#   };
#   # then append `precommit.shellHook` to the dev shell's shellHook.
{
  pkgs,
  # The *patched* pre-commit that git-hooks.nix builds. It understands
  # `language: "unsupported"`, which the generated .pre-commit-config.yaml uses
  # for our system hooks (alejandra etc.). pkgs.pre-commit is the plain upstream
  # build and rejects that config with InvalidConfigError.
  patchedPreCommit,
  # The `pre-commit-check` derivation produced by `git-hooks.lib.run`. Provides
  # the hook-install shellHook and the list of enabled hook-tool packages.
  preCommitCheck,
}: let
  inherit (pkgs) lib;

  # Wrap pre-commit so *manual* invocations on PATH run with a clean PYTHONPATH:
  # the artiq dev shell puts an unpatched pre-commit on PYTHONPATH that would
  # otherwise shadow the patched modules. (The git hooks get the same treatment
  # via the self-heal below.)
  wrapper = pkgs.writeShellScriptBin "pre-commit" ''
    unset PYTHONPATH
    exec ${patchedPreCommit}/bin/pre-commit "$@"
  '';

  # The git hooks need two repairs that git-hooks.nix's own shellHook does not
  # make, both of which otherwise break `git commit` / `git push` in this shell:
  #
  #   1. git-hooks.nix only (re)installs the hooks when the rendered config
  #      symlink changes, so hooks left over from an earlier setup (e.g. pointing
  #      at an unpatched pre-commit) survive and are never replaced. We reinstall
  #      whenever a hook isn't our patched one. git-hooks.nix manages both the
  #      pre-commit and pre-push hooks, so both are checked and reinstalled
  #      (`pre-commit install` only does pre-commit by default).
  #
  #   2. The artiq dev shell puts an *unpatched* pre-commit (pkgs.pre-commit, a
  #      pyaion dependency) on PYTHONPATH. pre-commit's generated hooks exec the
  #      pre-commit binary directly, so that unpatched module shadows the patched
  #      one and the hook dies with `InvalidConfigError: ... language:
  #      'unsupported'`. The wrapper above only guards manual calls, so we inject
  #      `unset PYTHONPATH` into every generated hook too.
  #
  # Both repairs are idempotent: on an already-healthy tree nothing changes.
  selfHeal = ''
    if commonDir=$(${pkgs.git}/bin/git rev-parse --path-format=absolute --git-common-dir 2>/dev/null); then
      hooksDir="$commonDir/hooks"

      # (1) Replace any hook that points at the wrong pre-commit.
      needsInstall=
      for ht in pre-commit pre-push; do
        if [ ! -e "$hooksDir/$ht" ] || ! grep -q "${patchedPreCommit}" "$hooksDir/$ht"; then
          needsInstall=1
        fi
      done
      if [ -n "$needsInstall" ]; then
        echo "git-hooks.nix: replacing stale git hooks" 1>&2
        # pre-commit install refuses to run with core.hooksPath set.
        ${pkgs.git}/bin/git config --local --unset-all core.hooksPath 2>/dev/null || true
        ( unset PYTHONPATH
          ${patchedPreCommit}/bin/pre-commit install -c .pre-commit-config.yaml --overwrite -t pre-commit -t pre-push )
        gitWc=$(${pkgs.git}/bin/git rev-parse --show-toplevel)
        ${pkgs.git}/bin/git config --local core.hooksPath "''${commonDir#$gitWc/}/hooks"
      fi

      # (2) Make every pre-commit-generated hook drop the polluted PYTHONPATH.
      for h in "$hooksDir"/*; do
        [ -f "$h" ] || continue
        grep -q "File generated by pre-commit" "$h" || continue
        grep -q '^unset PYTHONPATH$' "$h" && continue
        sed -i '/^exec .*pre-commit/i unset PYTHONPATH' "$h"
      done
    fi
  '';
in {
  inherit wrapper;

  # Shell hook fragment: run git-hooks.nix's installer, then put our wrapped
  # pre-commit and the hook tools on PATH, then self-heal.
  #
  # The PATH export must come *after* preCommitCheck.shellHook: git-hooks.nix
  # ends its shellHook with `export PATH=<raw patched pre-commit>:$PATH`, which
  # would otherwise shadow the wrapper and make manual `pre-commit` runs fail on
  # the polluted PYTHONPATH. Exporting afterwards keeps the wrapper first.
  shellHook =
    preCommitCheck.shellHook
    + ''
      export PATH="${wrapper}/bin:${lib.makeBinPath preCommitCheck.enabledPackages}:$PATH"
    ''
    + selfHeal;
}
