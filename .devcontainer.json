{
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "customizations": {
        "vscode": {
            "extensions": [
                "mkhl.direnv",
                "ms-python.black-formatter",
                "streetsidesoftware.code-spell-checker",
                "editorconfig.editorconfig",
                "mhutchie.git-graph",
                "tamasfe.even-better-toml",
                "donjayamanne.githistory",
                "gitlab.gitlab-workflow",
                "eamodio.gitlens",
                "npxms.hide-gitignored",
                "jnoortheen.nix-ide",
                "ms-python.python",
                "ms-python.debugpy",
                "stkb.rewrap",
                "gruntfuggly.todo-tree"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/nix:1": {
            "nixpkgs": "nixpkgs-24.05",
            "version": "2.24.9",
            "multiUser": false,
            "packages": ["direnv", "nix-direnv", "cachix", "pre-commit"],
            "extraNixConfig": "experimental-features = nix-command flakes,sandbox = false"
        }
    },
    "onCreateCommand": "cachix use aion-physics",
    // This is an annoying bugfix. See https://www.kenmuse.com/blog/avoiding-dubious-ownership-in-dev-containers/
    "updateContentCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && direnv allow",
    "postCreateCommand": "nix develop -c echo devShell build import successful && nix develop -c pre-commit install --install-hooks"
}
